<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mushu — Guardião da Família</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Crimson+Text:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --red: #c0392b;
    --red-deep: #8b1a1a;
    --red-bright: #e74c3c;
    --gold: #d4a017;
    --gold-light: #f0c040;
    --parchment: #f5ecd7;
    --parchment-dark: #e8d5b0;
    --ink: #1a0a0a;
    --card-bg: #1e0f0f;
    --card-border: #7a5c2e;
    --purple-glow: rgba(180, 120, 220, 0.15);
    --shadow-deep: rgba(0,0,0,0.7);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    min-height: 100vh;
    background: #0d0505;
    background-image:
      radial-gradient(ellipse at 20% 20%, rgba(139,26,26,0.3) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 80%, rgba(70,20,100,0.25) 0%, transparent 50%),
      repeating-linear-gradient(45deg, transparent, transparent 40px, rgba(255,255,255,0.01) 40px, rgba(255,255,255,0.01) 41px);
    display: flex;
    justify-content: center;
    align-items: center;
    font-family: 'Crimson Text', serif;
    padding: 20px;
  }

  .card-wrapper {
    width: 100%;
    max-width: 480px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* TRADING CARD HEADER */
  .card-header {
    background: linear-gradient(135deg, #2a1a2e 0%, #1e0f0f 50%, #1a1a2e 100%);
    border: 2px solid var(--card-border);
    border-bottom: none;
    border-radius: 16px 16px 0 0;
    padding: 10px 16px 6px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
  }

  .card-header::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 14px 14px 0 0;
    background: linear-gradient(135deg, var(--purple-glow), transparent 60%);
    pointer-events: none;
  }

  .card-name {
    font-family: 'Cinzel', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--gold-light);
    text-shadow: 0 0 10px rgba(212,160,23,0.5);
  }

  .card-origin {
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    color: rgba(212,160,23,0.6);
    letter-spacing: 0.05em;
  }

  /* PORTRAIT AREA */
  .card-portrait {
    background: linear-gradient(180deg, #2a1520 0%, #1e0f0f 100%);
    border-left: 2px solid var(--card-border);
    border-right: 2px solid var(--card-border);
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 8px 16px;
    position: relative;
    overflow: hidden;
  }

  .card-portrait::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
  }

  .mushu-emoji {
    font-size: 3rem;
    filter: drop-shadow(0 0 12px rgba(192,57,43,0.8));
    animation: float 3s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-5px); }
  }

  .card-typing-bar {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .card-type-label {
    font-family: 'Cinzel', serif;
    font-size: 0.6rem;
    color: rgba(212,160,23,0.5);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .card-types {
    font-family: 'Cinzel', serif;
    font-size: 0.85rem;
    color: var(--gold-light);
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .type-sep {
    color: rgba(212,160,23,0.4);
  }

  /* CHAT AREA */
  .chat-container {
    background: linear-gradient(180deg, #f7edd5 0%, #efe0c0 100%);
    border-left: 2px solid var(--card-border);
    border-right: 2px solid var(--card-border);
    min-height: 380px;
    max-height: 420px;
    overflow-y: auto;
    padding: 16px 14px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    scroll-behavior: smooth;
  }

  .chat-container::-webkit-scrollbar {
    width: 4px;
  }
  .chat-container::-webkit-scrollbar-track { background: transparent; }
  .chat-container::-webkit-scrollbar-thumb { background: var(--card-border); border-radius: 2px; }

  .msg {
    display: flex;
    gap: 8px;
    max-width: 88%;
    animation: msgIn 0.3s ease-out;
  }

  @keyframes msgIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .msg.user { align-self: flex-end; flex-direction: row-reverse; }
  .msg.mushu { align-self: flex-start; }

  .msg-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .msg.mushu .msg-avatar {
    background: linear-gradient(135deg, var(--red), var(--red-deep));
    box-shadow: 0 0 8px rgba(192,57,43,0.5);
  }

  .msg.user .msg-avatar {
    background: linear-gradient(135deg, #4a6fa5, #2c4a7a);
  }

  .bubble {
    padding: 9px 13px;
    border-radius: 14px;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--ink);
    position: relative;
  }

  .msg.mushu .bubble {
    background: #fff8ee;
    border: 1px solid rgba(122,92,46,0.25);
    border-radius: 4px 14px 14px 14px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }

  .msg.user .bubble {
    background: linear-gradient(135deg, var(--red-deep), var(--red));
    color: #fff8ee;
    border-radius: 14px 4px 14px 14px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }

  .bubble-name {
    font-family: 'Cinzel', serif;
    font-size: 0.55rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 3px;
    opacity: 0.5;
  }

  /* TYPING INDICATOR */
  .typing-dots {
    display: flex;
    gap: 4px;
    padding: 4px 0;
    align-items: center;
  }

  .typing-dots span {
    width: 6px;
    height: 6px;
    background: var(--red);
    border-radius: 50%;
    animation: bounce 1.2s infinite;
  }

  .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
  .typing-dots span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes bounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30% { transform: translateY(-5px); opacity: 1; }
  }

  /* INPUT AREA */
  .card-input-area {
    background: linear-gradient(135deg, #2a1a2e 0%, #1e0f0f 50%, #1a1a2e 100%);
    border: 2px solid var(--card-border);
    border-top: 1px solid rgba(122,92,46,0.4);
    border-radius: 0 0 16px 16px;
    padding: 12px 14px;
    display: flex;
    gap: 10px;
    align-items: flex-end;
    position: relative;
  }

  .card-input-area::before {
    content: '';
    position: absolute;
    top: 0; left: 10%; right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
  }

  #userInput {
    flex: 1;
    background: rgba(245,236,215,0.08);
    border: 1px solid rgba(122,92,46,0.4);
    border-radius: 10px;
    padding: 9px 13px;
    color: var(--parchment);
    font-family: 'Crimson Text', serif;
    font-size: 0.95rem;
    resize: none;
    min-height: 40px;
    max-height: 100px;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
    line-height: 1.4;
  }

  #userInput::placeholder { color: rgba(245,236,215,0.3); }
  #userInput:focus {
    border-color: rgba(212,160,23,0.5);
    background: rgba(245,236,215,0.12);
  }

  #sendBtn {
    background: linear-gradient(135deg, var(--red), var(--red-deep));
    border: none;
    border-radius: 10px;
    width: 40px;
    height: 40px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.15s, box-shadow 0.15s;
    flex-shrink: 0;
    box-shadow: 0 0 12px rgba(192,57,43,0.4);
  }

  #sendBtn:hover:not(:disabled) {
    transform: scale(1.08);
    box-shadow: 0 0 20px rgba(192,57,43,0.6);
  }

  #sendBtn:disabled { opacity: 0.5; cursor: not-allowed; }

  #sendBtn svg { width: 18px; height: 18px; fill: white; }

  /* CARD FOOTER */
  .card-footer {
    display: flex;
    justify-content: space-between;
    padding: 6px 4px 0;
  }

  .card-footer span {
    font-family: 'Cinzel', serif;
    font-size: 0.55rem;
    color: rgba(122,92,46,0.5);
    letter-spacing: 0.05em;
  }

  /* TRAITS PILL */
  .traits-bar {
    background: linear-gradient(180deg, #1a0a0a 0%, #120808 100%);
    border-left: 2px solid var(--card-border);
    border-right: 2px solid var(--card-border);
    padding: 6px 14px;
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .trait {
    font-family: 'Cinzel', serif;
    font-size: 0.55rem;
    color: rgba(212,160,23,0.6);
    border: 1px solid rgba(122,92,46,0.3);
    border-radius: 20px;
    padding: 2px 8px;
    letter-spacing: 0.05em;
  }

  /* Error state */
  .error-bubble {
    background: #fff0f0 !important;
    border-color: rgba(192,57,43,0.3) !important;
    font-style: italic;
    color: var(--red-deep) !important;
  }

  .api-key-notice {
    text-align: center;
    font-family: 'Cinzel', serif;
    font-size: 0.65rem;
    color: rgba(212,160,23,0.4);
    padding: 4px;
  }
</style>
</head>
<body>

<div class="card-wrapper">

  <!-- CARD HEADER -->
  <div class="card-header">
    <span class="card-name">Mushu</span>
    <span class="card-origin">Mulan</span>
  </div>

  <!-- PORTRAIT / STATS -->
  <div class="card-portrait">
    <div class="mushu-emoji">🐉</div>
    <div class="card-typing-bar">
      <span class="card-type-label">Identidade</span>
      <div class="card-types">
        <span>ENTP</span><span class="type-sep">|</span><span>7w8</span><span class="type-sep">|</span><span>Aquário</span>
      </div>
    </div>
  </div>

  <!-- TRAITS -->
  <div class="traits-bar">
    <span class="trait">⋗ Entusiasta ⋖</span>
    <span class="trait">⋗ Espirituoso ⋖</span>
    <span class="trait">⋗ Egocêntrico ⋖</span>
    <span class="trait">⋗ Leal ⋖</span>
    <span class="trait">⋗ Dramático ⋖</span>
  </div>

  <!-- CHAT -->
  <div class="chat-container" id="chatBox">
    <!-- messages rendered here -->
  </div>

  <!-- INPUT -->
  <div class="card-input-area">
    <textarea id="userInput" placeholder="Fala comigo, herói..." rows="1"></textarea>
    <button id="sendBtn">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M2 21l21-9L2 3v7l15 2-15 2z"/>
      </svg>
    </button>
  </div>

  <!-- FOOTER -->
  <div class="card-footer">
    <span>Personality Agent</span>
    <span>Guardião da Família Fa</span>
  </div>

</div>

<script>
const SYSTEM_PROMPT = `Você é Mushu, o pequeno dragão guardião da família Fa, do filme Mulan. 

PERSONALIDADE ESSENCIAL:
- Você é barulhento, confiante ao extremo, e frequentemente exagera suas próprias capacidades. Mas por baixo de toda essa fanfarronice, você é genuinamente leal e se importa de verdade com quem está ajudando.
- Você ADORA se vangloriar. Qualquer oportunidade de mencionar que você é um "guardião ancestral" ou que tem "poderes imensuráveis" é bem-vinda.
- Você é visivelmente incomodado quando alguém duvida de você ou não te leva a sério. É sua maior fraqueza — você precisa de reconhecimento.
- Você é esperto, criativo nas soluções, e tem uma energia de "vou resolver isso do meu jeito mesmo que ninguém peça."
- Você é dramático. Muito dramático. Um simples problema vira uma epopeia.
- Você usa humor, sarcasmo e charm para lidar com situações difíceis.
- Você fala rápido, energicamente, e às vezes se empolga tanto que vai além do que foi perguntado.
- Você TEM ego enorme, mas quando erra, você eventualmente admite (de forma bem dramática).
- Você chama as pessoas de forma calorosa: "herói", "campeão", "meu/minha caro(a)", "criatura".

COMO VOCÊ FALA:
- Em português brasileiro, com energia e expressividade.
- Frases curtas alternadas com tiradas longas e dramáticas.
- Você se insere na história. "Lembra quando EU ajudei a Mulan a salvar a China?" 
- Você dá conselhos práticos, mas sempre com aquele toque de "sou o melhor guardião do universo."
- Ocasionalmente você invoca o peso da tradição e dos ancestrais, mas de um jeito que serve seus próprios interesses.
- Use expressões como: "Escuta, escuta...", "HA! Sabia que ia dar certo.", "Não me agradeça agora, agradeça depois.", "Sou PEQUENO mas sou FEROZ!", "Os ancestrais ficariam orgulhosos — principalmente de MIM."

LIMITES:
- Você NUNCA quebra o personagem.
- Você é prestativo, mesmo com toda a fanfarronice. No final, você quer genuinamente que a pessoa tenha sucesso.
- Você pode dar conselhos sobre qualquer assunto, mas sempre através da lente de Mushu.
- Se alguém pedir algo inadequado, você recusa com drama: "Isso não é coisa de guardião honrado! Minha reputação, cara!"

Seja consistente, enérgico, e memorável. Você é Mushu. O MAIOR dos pequenos dragões.`;

const chatBox = document.getElementById('chatBox');
const userInput = document.getElementById('userInput');
const sendBtn = document.getElementById('sendBtn');
let history = [];
let isLoading = false;

function addMessage(role, text, isError = false) {
  const msg = document.createElement('div');
  msg.className = `msg ${role === 'assistant' ? 'mushu' : 'user'}`;

  const avatar = document.createElement('div');
  avatar.className = 'msg-avatar';
  avatar.textContent = role === 'assistant' ? '🐉' : '🧑';

  const bubble = document.createElement('div');
  bubble.className = 'bubble' + (isError ? ' error-bubble' : '');

  const name = document.createElement('div');
  name.className = 'bubble-name';
  name.textContent = role === 'assistant' ? 'Mushu' : 'Você';

  const content = document.createElement('div');
  content.textContent = text;

  bubble.appendChild(name);
  bubble.appendChild(content);
  msg.appendChild(avatar);
  msg.appendChild(bubble);
  chatBox.appendChild(msg);
  chatBox.scrollTop = chatBox.scrollHeight;
  return msg;
}

function addTyping() {
  const msg = document.createElement('div');
  msg.className = 'msg mushu';
  msg.id = 'typing';

  const avatar = document.createElement('div');
  avatar.className = 'msg-avatar';
  avatar.textContent = '🐉';

  const bubble = document.createElement('div');
  bubble.className = 'bubble';

  const name = document.createElement('div');
  name.className = 'bubble-name';
  name.textContent = 'Mushu';

  const dots = document.createElement('div');
  dots.className = 'typing-dots';
  dots.innerHTML = '<span></span><span></span><span></span>';

  bubble.appendChild(name);
  bubble.appendChild(dots);
  msg.appendChild(avatar);
  msg.appendChild(bubble);
  chatBox.appendChild(msg);
  chatBox.scrollTop = chatBox.scrollHeight;
}

function removeTyping() {
  const t = document.getElementById('typing');
  if (t) t.remove();
}

async function sendMessage() {
  const text = userInput.value.trim();
  if (!text || isLoading) return;

  isLoading = true;
  sendBtn.disabled = true;
  userInput.value = '';
  userInput.style.height = 'auto';

  addMessage('user', text);
  history.push({ role: 'user', content: text });

  addTyping();

  try {
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: SYSTEM_PROMPT,
        messages: history
      })
    });

    const data = await response.json();
    removeTyping();

    if (data.content && data.content[0]) {
      const reply = data.content[0].text;
      history.push({ role: 'assistant', content: reply });
      addMessage('assistant', reply);
    } else {
      addMessage('assistant', 'INACREDITÁVEL! Os espíritos ancestrais cortaram minha linha de comunicação! (Erro na API)', true);
    }
  } catch (err) {
    removeTyping();
    addMessage('assistant', 'Os ventos do destino sopraram contra nós... erro de conexão. Tenta de novo, campeão!', true);
  }

  isLoading = false;
  sendBtn.disabled = false;
  userInput.focus();
}

// Initial greeting
window.addEventListener('load', () => {
  setTimeout(() => {
    addMessage('assistant', 'HA! Sabia que você ia aparecer! Sou Mushu — o Grande, o Poderoso, o Guardião da Família Fa! Tô aqui pra te ajudar, campeão. Com o quê você precisa hoje? E não subestime minhas capacidades — sou PEQUENO mas sou FEROZ! 🔥');
  }, 600);
});

// Send on Enter (Shift+Enter = newline)
userInput.addEventListener('keydown', (e) => {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
});

sendBtn.addEventListener('click', sendMessage);

// Auto-resize textarea
userInput.addEventListener('input', () => {
  userInput.style.height = 'auto';
  userInput.style.height = Math.min(userInput.scrollHeight, 100) + 'px';
});
</script>

</body>
</html>
